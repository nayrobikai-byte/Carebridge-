<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CareBridge Professional Dashboard</title><link rel="stylesheet" href="../assets/css/style.css"><style>
.dashboard-container{
    display:flex;
    min-height:100vh;
}

.sidebar{
    width:260px;
    background:#0A2342;
    color:white;
    padding:25px;
}

.sidebar h2{
    color:#D4AF37;
    margin-bottom:30px;
}

.sidebar a{
    display:block;
    color:white;
    text-decoration:none;
    padding:12px;
    margin-bottom:10px;
    border-radius:6px;
}

.sidebar a:hover{
    background:#1B998B;
}

.main-content{
    flex:1;
    padding:30px;
    background:#F5F7FA;
}

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-bottom:30px;
}

.stat-card{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.card{
    background:white;
    padding:25px;
    border-radius:10px;
    margin-bottom:25px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

input,
select,
textarea{
    width:100%;
    padding:12px;
    border:1px solid #ddd;
    border-radius:6px;
    margin-bottom:15px;
}

button{
    background:#D4AF37;
    color:#0A2342;
    border:none;
    padding:12px 20px;
    border-radius:6px;
    font-weight:bold;
    cursor:pointer;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#0A2342;
    color:white;
    padding:12px;
}

td{
    padding:12px;
    border-bottom:1px solid #ddd;
}
</style></head><body><div class="dashboard-container"><div class="sidebar"><h2>CareBridge</h2><a href="#">Dashboard</a>
<a href="#">My Profile</a>
<a href="#">Resume</a>
<a href="#">Credentials</a>
<a href="#">Applications</a>
<a href="#">Interviews</a>
<a href="#">Timesheets</a>
<a href="#">Payroll</a>
<a href="#">Messages</a>
<a href="#">Settings</a>

