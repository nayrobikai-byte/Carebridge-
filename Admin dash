<title>CareBridge Admin Dashboard</title><link rel="stylesheet" href="../assets/css/style.css"><style>
.dashboard-container{
    display:flex;
    min-height:100vh;
}

.sidebar{
    width:280px;
    background:#0A2342;
    color:white;
    padding:25px;
}

.sidebar h2{
    color:#D4AF37;
    margin-bottom:30px;
}

.sidebar a{
    display:block;
    color:white;
    text-decoration:none;
    padding:12px;
    margin-bottom:10px;
    border-radius:6px;
}

.sidebar a:hover{
    background:#1B998B;
}

.main-content{
    flex:1;
    padding:30px;
    background:#F5F7FA;
}

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-bottom:30px;
}

.stat-card{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.stat-card h2{
    color:#1B998B;
}

.card{
    background:white;
    padding:25px;
    border-radius:10px;
    margin-bottom:25px;
    box-shadow:0 5px 15px rgba(0,0,0,.08);
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#0A2342;
    color:white;
    padding:12px;
}

td{
    padding:12px;
    border-bottom:1px solid #ddd;
}

.action-btn{
    background:#D4AF37;
    color:#0A2342;
    border:none;
    padding:8px 12px;
    border-radius:5px;
    cursor:pointer;
    font-weight:bold;
}

.approved{
    color:green;
    font-weight:bold;
}

.pending{
    color:#c77b00;
    font-weight:bold;
}
